apiVersion: v1
kind: LimitRange
metadata:
  name: {{appName}}-limits
  namespace: {{namespace}}
  labels:
    app: {{appName}}
spec:
  limits:
    - type: Container
      defaultRequest:
        cpu: {{cpuRequest}}
        memory: {{memoryRequest}}
      default:
        cpu: {{cpuLimit}}
        memory: {{memoryLimit}}
