apiVersion: apps/v1
kind: StatefulSet
metadata:
  name: {{appName}}
  namespace: {{namespace}}
  labels:
    app: {{appName}}
    app.kubernetes.io/managed-by: devops-platform
spec:
  serviceName: {{appName}}
  replicas: {{replicas}}
  selector:
    matchLabels:
      app: {{appName}}
  template:
    metadata:
      labels:
        app: {{appName}}
    spec:
{{#if serviceAccountName}}
      serviceAccountName: {{serviceAccountName}}
{{/if}}
      containers:
        - name: {{appName}}
          image: {{image}}
          ports:
            - containerPort: {{containerPort}}
{{#if hasConfigMap}}
          envFrom:
            - configMapRef:
                name: {{appName}}-config
{{#if hasSecret}}
            - secretRef:
                name: {{appName}}-secret
{{/if}}
{{else if hasSecret}}
          envFrom:
            - secretRef:
                name: {{appName}}-secret
{{/if}}
          resources:
            requests:
              cpu: {{resources.cpuRequest}}
              memory: {{resources.memoryRequest}}
            limits:
              cpu: {{resources.cpuLimit}}
              memory: {{resources.memoryLimit}}
{{#if healthChecks.enabled}}
          readinessProbe:
            httpGet:
              path: {{healthChecks.endpoint}}
              port: {{containerPort}}
            initialDelaySeconds: 5
            periodSeconds: 10
          livenessProbe:
            httpGet:
              path: {{healthChecks.endpoint}}
              port: {{containerPort}}
            initialDelaySeconds: 15
            periodSeconds: 20
{{/if}}
{{#if volume.enabled}}
          volumeMounts:
            - name: {{appName}}-storage
              mountPath: {{volume.mountPath}}
      volumes:
        - name: {{appName}}-storage
          persistentVolumeClaim:
            claimName: {{appName}}-pvc
{{/if}}
