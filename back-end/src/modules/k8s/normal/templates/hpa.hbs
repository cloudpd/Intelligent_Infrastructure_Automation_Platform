apiVersion: autoscaling/v2
kind: HorizontalPodAutoscaler
metadata:
  name: {{appName}}-hpa
  namespace: {{namespace}}
  labels:
    app: {{appName}}
spec:
  scaleTargetRef:
    apiVersion: apps/v1
    kind: {{workloadType}}
    name: {{appName}}
  minReplicas: {{minReplicas}}
  maxReplicas: {{maxReplicas}}
  metrics:
    - type: Resource
      resource:
        name: cpu
        target:
          type: Utilization
          averageUtilization: {{targetCPU}}
{{#if targetMemory}}
    - type: Resource
      resource:
        name: memory
        target:
          type: Utilization
          averageUtilization: {{targetMemory}}
{{/if}}
