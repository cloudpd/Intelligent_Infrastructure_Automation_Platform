apiVersion: networking.k8s.io/v1
kind: Ingress
metadata:
  name: {{appName}}
  namespace: {{namespace}}
  labels:
    app: {{appName}}
spec:
  ingressClassName: {{ingressClass}}
{{#if tlsEnabled}}
  tls:
    - hosts:
        - {{host}}
      secretName: {{appName}}-tls
{{/if}}
  rules:
    - host: {{host}}
      http:
        paths:
          - path: {{path}}
            pathType: Prefix
            backend:
              service:
                name: {{appName}}
                port:
                  number: {{containerPort}}
